# Copy this file to .env and adjust as needed.

# Port the server runs on
PORT=5000

# Secret used to sign admin login tokens — change this to a long random string before deploying anywhere public
JWT_SECRET=change_this_to_a_long_random_string

# Default admin account, created automatically the first time the server starts
# (only used if no admin account exists yet in db.json)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
